<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <style>
            body {
                font-family: Arial, sans-serif;
                background-color: #f4f4f4;
                color: #333;
                line-height: 1.6;
            }

            .container {
                max-width: 1200px;
                margin: auto;
                padding: 20px;
                display: flex;
                flex-wrap: wrap;
                gap: 20px;
            }

            .card {
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
                background-color: #fff;
                width: 300px;
            }

            .card-img-top {
                width: 100%;
                height: 180px;
                object-fit: cover;
            }

            .btn-primary {
                background-color: #007bff;
                border: none;
                padding: 10px 20px;
                color: white;
                text-transform: uppercase;
            }

            .btn-primary:hover {
                background-color: #0056b3;
            }
        </style>
        <title>Homepage</title>
</head>

<body>
    <%- include('./partials/nav') %>

        <div class="container mt-3">
            <% blogs.forEach(blog=> { %>
                <div class="card">
                    <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="<%= blog.title %> cover image">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= blog.title %>
                        </h5>
                        <a href="/blog/<%= blog._id %>" class="btn btn-primary">View</a>
                    </div>
                </div>
                <% }) %>
        </div>

        <%- include('./partials/scripts') %>
</body>

</html>